{
  "name": "fgeha-nlc-server",
  "version": "0.1.0",
  "private": true,
  "description": "Reference on-prem backend scaffold for FGEHA × NLC Unified Project Control",
  "type": "commonjs",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/index.js",
    "migrate": "node scripts/migrate.js",
    "dev": "ts-node src/index.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "pg": "^8.11.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.7",
    "@types/pg": "^8.11.5",
    "pg-mem": "^3.0.5",
    "typescript": "^5.4.5",
    "vitest": "^2.1.9"
  }
}
